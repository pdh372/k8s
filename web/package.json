{
    "name": "k8s-interview-prep",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "description": "Visual Kubernetes interview-prep web app built from the team's CKA-style lesson notes.",
    "scripts": {
        "gen": "node scripts/generate-content.mjs",
        "predev": "npm run gen",
        "dev": "vite",
        "prebuild": "npm run gen",
        "build": "tsc --noEmit && vite build",
        "preview": "vite preview"
    },
    "dependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-markdown": "^9.0.1",
        "react-router-dom": "^6.26.2",
        "rehype-highlight": "^7.0.0",
        "remark-gfm": "^4.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.3.5",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.20",
        "highlight.js": "^11.10.0",
        "postcss": "^8.4.47",
        "tailwindcss": "^3.4.13",
        "typescript": "^5.6.2",
        "vite": "^5.4.8"
    }
}